{
  "name": "vesta-client",
  "version": "0.1.0",
  "description": "TypeScript client library for the Vesta protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "test": "tsc && node --test tests/*.test.mjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "vesta",
    "protocol",
    "websocket",
    "event-sourcing"
  ],
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  }
}
